# LangSmith Observability (optional but recommended)
# Sign up at https://smith.langchain.com to get your API key
# If you're in the EU, use: https://eu.api.smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_your_api_key_here
LANGSMITH_PROJECT=rag-oca-f1

# LLM Provider: "ollama" (default, local) or "openrouter" (cloud API)
LLM_PROVIDER=openrouter

# --- Ollama (local models) ---
# OLLAMA_MODEL_PRIORITY=tinyllama,qwen3.5:0.8b,phi3

# --- OpenRouter (cloud models) ---
# Get your key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_MODEL=openai/gpt-4o-mini

# OpenRouter embedding model (uses the same API key above)
# Available: openai/text-embedding-3-large, openai/text-embedding-3-small,
#            qwen/qwen3-embedding-8b, google/gemini-embedding-2-preview
OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-8b:deepinfra

# RAG server startup mode: lazy (default), blocking, or background
RAG_STARTUP_MODE=lazy

# Silence LEANN's verbose tqdm progress bars (set to WARNING or ERROR)
LEANN_LOG_LEVEL=WARNING
